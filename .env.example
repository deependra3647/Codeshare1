# Copy this to .env and fill in values

# MongoDB connection (required for download logging)
MONGO_URI=mongodb://127.0.0.1:27017/codeshare
MONGO_DB_NAME=codeshare

# Port for the Express server (default: 5000)
PORT=5000

# Only needed for local frontend dev (leave blank in production)
REACT_APP_BACKEND_URL=http://localhost:5000
